# .env.example — Copy to .env.local and fill in your values

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/prowider_db"

# Webhook secret — must match x-webhook-secret header in all webhook calls
WEBHOOK_SECRET="prowider-webhook-secret-2024"

# Expose webhook secret to browser (for test-tools page only)
# In production, test-tools should be admin-only or removed
NEXT_PUBLIC_WEBHOOK_SECRET="prowider-webhook-secret-2024"


